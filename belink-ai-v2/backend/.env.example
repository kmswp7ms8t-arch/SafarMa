# Server-side only. Never copy this value into frontend/config.js.
OPENAI_API_KEY=
BELINK_AI_MODEL=gpt-5-mini
BELINK_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
BELINK_AI_DATABASE=./data/belink_ai.sqlite3
